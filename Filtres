BAD_WORDS = [
    "казино",
    "ставки",
    "скам",
    "реклама",
    "купить подписчиков",
    "заработок"
]


def contains_bad_words(text: str):

    if not text:
        return False

    text = text.lower()

    for word in BAD_WORDS:
        if word in text:
            return True

    return False
